# ---------------------------------------------------------------------------
# Copy this file to ".env" and fill in the values from your Supabase project
# (Project Settings -> API).
# ---------------------------------------------------------------------------

# ---- Client-side (safe to ship to the browser) ----
# These are exposed in the built bundle. ONLY the anon key goes here.
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# ---- Server-side ONLY (never shipped to the browser) ----
# Used by the /api serverless functions to create auth users from the admin
# panel. NEVER prefix these with VITE_ and NEVER expose them client-side.
# On Vercel, set these in Project Settings -> Environment Variables.
SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

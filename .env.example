# ---------------------------------------------------------------------------
# Copy this file to ".env" and fill in the values from your Supabase project
# (Project Settings -> API) and MSG91 account.
# ---------------------------------------------------------------------------

# ---- Client-side (safe to ship to the browser) ----
# These are exposed in the built bundle. ONLY the anon key goes here.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ---- Server-side ONLY (never shipped to the browser) ----
# Used by the /api serverless functions (create accounts, reset password,
# send SMS, messaging). NEVER prefix these with VITE_ and NEVER expose them
# client-side. On Vercel, set these in Project Settings -> Environment Variables.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ---- SMS (MSG91) ----
# VITE_MSG91_API_KEY gates the SMS UI client-side AND is used as a fallback by
# the server-side SMS proxy (api/send-sms.js). Optionally set MSG91_API_KEY as a
# server-only key to keep it out of the client bundle.
VITE_MSG91_API_KEY=your_msg91_api_key
VITE_MSG91_SENDER_ID=BJPSCH
# Required by the MSG91 v5 flow API once DLT registration is approved:
VITE_MSG91_TEMPLATE_ID=
# Optional server-only MSG91 key (preferred for production):
# MSG91_API_KEY=your_msg91_api_key

# ---- WhatsApp (Meta WhatsApp Business Cloud API) ----
# Server-only. When WHATSAPP_ACCESS_TOKEN + WHATSAPP_PHONE_NUMBER_ID are set, the
# attendance and fee flows use WhatsApp automatically and fall back to SMS only if
# WhatsApp is not configured. No client (VITE_) keys are needed. Set on Vercel in
# Project Settings -> Environment Variables.
WHATSAPP_ACCESS_TOKEN=your_permanent_access_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_BUSINESS_ACCOUNT_ID=your_waba_id
# Approved Meta template names (override the built-in defaults below):
WHATSAPP_ATTENDANCE_TEMPLATE=attendance_alert
WHATSAPP_FEE_TEMPLATE=fee_reminder

# ---- Misc ----
VITE_SCHOOL_NAME=Bala Ji Public School
